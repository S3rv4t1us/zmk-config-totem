#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
//             | SW01  | SW02  | SW03  | SW04  | SW05  |  | SW05  | SW04  | SW03  | SW02  | SW01  |
//             | SW06  | SW07  | SW08  | SW09  | SW10  |  | SW10  | SW09  | SW08  | SW07  | SW06  | 
//      | SW16 | SW11  | SW12  | SW13  | SW14  | SW15  |  | SW15  | SW14  | SW13  | SW12  | SW11  | SW16  |
//                             | SW17  | SW18  | SW19  |  | SW19  | SW18  | SW17  | 
        map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
        RC(3,0) RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(3,9)
                                RC(3,2) RC(3,3) RC(3,4)    RC(3,5) RC(3,6) RC(3,7)         
        >;
    };


    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Totem";
        transform = <&default_transform>;
        keys //                     w   h    x    y     r   rx   ry
            = <&key_physical_attrs 100 100  100   75    0    0    0>  // RC(0,0) Q
            , <&key_physical_attrs 100 100  200   25    0    0    0>  // RC(0,1) W
            , <&key_physical_attrs 100 100  300    0    0    0    0>  // RC(0,2) E
            , <&key_physical_attrs 100 100  400   25    0    0    0>  // RC(0,3) R
            , <&key_physical_attrs 100 100  500   50    0    0    0>  // RC(0,4) T
            , <&key_physical_attrs 100 100  700   50    0    0    0>  // RC(0,5) Y
            , <&key_physical_attrs 100 100  800   25    0    0    0>  // RC(0,6) U
            , <&key_physical_attrs 100 100  900    0    0    0    0>  // RC(0,7) I
            , <&key_physical_attrs 100 100 1000   25    0    0    0>  // RC(0,8) P
            , <&key_physical_attrs 100 100 1100   75    0    0    0>  // RC(0,9)
            , <&key_physical_attrs 100 100  100  175    0    0    0>  // RC(1,0) A
            , <&key_physical_attrs 100 100  200  125    0    0    0>  // RC(1,1) S
            , <&key_physical_attrs 100 100  300  100    0    0    0>  // RC(1,2) D
            , <&key_physical_attrs 100 100  400  125    0    0    0>  // RC(1,3) F
            , <&key_physical_attrs 100 100  500  150    0    0    0>  // RC(1,4) G
            , <&key_physical_attrs 100 100  700  150    0    0    0>  // RC(1,5) H
            , <&key_physical_attrs 100 100  800  125    0    0    0>  // RC(1,6) J
            , <&key_physical_attrs 100 100  900  100    0    0    0>  // RC(1,7) K
            , <&key_physical_attrs 100 100 1000  125    0    0    0>  // RC(1,8) L
            , <&key_physical_attrs 100 100 1100  175    0    0    0>  // RC(1,9) O
            , <&key_physical_attrs 100 100    0  275    0    0    0>  // RC(3,0) LSHFT outer
            , <&key_physical_attrs 100 100  100  275    0    0    0>  // RC(2,0) Z
            , <&key_physical_attrs 100 100  200  225    0    0    0>  // RC(2,1) X
            , <&key_physical_attrs 100 100  300  200    0    0    0>  // RC(2,2) C
            , <&key_physical_attrs 100 100  400  225    0    0    0>  // RC(2,3) V
            , <&key_physical_attrs 100 100  500  250    0    0    0>  // RC(2,4) B
            , <&key_physical_attrs 100 100  700  250    0    0    0>  // RC(2,5) N
            , <&key_physical_attrs 100 100  800  225    0    0    0>  // RC(2,6) M
            , <&key_physical_attrs 100 100  900  200    0    0    0>  // RC(2,7) ,
            , <&key_physical_attrs 100 100 1000  225    0    0    0>  // RC(2,8) .
            , <&key_physical_attrs 100 100 1100  275    0    0    0>  // RC(2,9) /
            , <&key_physical_attrs 100 100 1200  275    0    0    0>  // RC(3,9) RSHFT outer
            , <&key_physical_attrs 100 100  325  375    0    0    0>  // RC(3,2) ESC/SYM
            , <&key_physical_attrs 100 100  425  400    0    0    0>  // RC(3,3) BSP/NAV
            , <&key_physical_attrs 100 100  525  400    0    0    0>  // RC(3,4) ENT/ADJ
            , <&key_physical_attrs 100 100  675  400    0    0    0>  // RC(3,5) TAB/ADJ
            , <&key_physical_attrs 100 100  775  400    0    0    0>  // RC(3,6) SPC/NAV
            , <&key_physical_attrs 100 100  875  375    0    0    0>  // RC(3,7) DEL/SYM
            ;
    };
};